APP_NAME=AI私厨 Backend
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
FRONTEND_ORIGIN=http://localhost:5173

# ==============================
# 模型配置
# ==============================

# 文本模型配置（用于对话，默认使用 Minimax）
TEXT_API_KEY=your_text_api_key
TEXT_GROUP_ID=your_text_group_id_if_needed
TEXT_BASE_URL=https://api.minimax.chat/v1
TEXT_MODEL=MiniMax-M2.7

# 视觉模型配置（用于食材识别，默认使用 Qwen）
VISION_API_KEY=your_vision_api_key
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-plus-latest
MINIMAX_TIMEOUT=60

# 未配置 SK 时，是否允许返回 mock 结果，便于前端联调
ALLOW_MOCK_WITHOUT_KEY=true

# ==============================
# 备用模型供应商配置（可选）
# 当前代码默认主链路使用 Minimax；以下用于后续扩展或切换
# ==============================

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通义千问（Qwen / DashScope OpenAI Compatible）
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Kimi（Moonshot）
KIMI_API_KEY=your_kimi_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=your_aliyun_access_key_id
OSS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_DOMAIN=https://your_bucket_name.oss-cn-hangzhou.aliyuncs.com
OSS_OBJECT_PREFIX=chefagent/uploads
